{
  "name": "mental-models",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "author": "Alejandro Fernández Camello",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "NODE_OPTIONS=--max-old-space-size=12288 astro build",
    "preview": "astro preview",
    "test": "bun test",
    "astro": "astro",
    "check": "bun run check:latex && bun run check:island-latex && astro check && tsc --noEmit",
    "check:latex": "bun run scripts/check-latex.ts",
    "check:island-latex": "bun run scripts/check-island-latex.ts",
    "audit": "bun audit --ignore GHSA-gv7w-rqvm-qjhr --ignore GHSA-g7r4-m6w7-qqqr",
    "audit:fix": "bun update && bun run audit",
    "og:generate": "bun run scripts/generate-og.ts",
    "og:changed": "bun run scripts/generate-og.ts --changed",
    "og:build": "bun run build && bun run og:generate",
    "pre-commit": "bun run check && bun run build && bun run og:changed"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.7",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "katex": "^0.17.0",
    "playwright": "^1.61.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "path-to-regexp": ">=6.3.0 <7",
    "tar": ">=7.5.16",
    "vite": ">=7.3.5 <8",
    "js-yaml": ">=4.2.0"
  }
}
