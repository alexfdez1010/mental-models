---
/**
 * 404 — friendly branded not-found page. Locale derived from the URL.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const copy = {
  en: {
    title: 'Page not found',
    body: "We couldn't find the page you were looking for. It may have moved or never existed.",
    home: 'Back to home',
    catalog: t('hero.cta.catalog'),
  },
  es: {
    title: 'Página no encontrada',
    body: 'No pudimos encontrar la página que buscabas. Puede que se haya movido o que nunca existiera.',
    home: 'Volver al inicio',
    catalog: t('hero.cta.catalog'),
  },
}[lang];
---

<BaseLayout
  title={copy.title}
  description={copy.body}
  lang={lang}
  noindex={true}
  mainClass="mx-auto flex w-full max-w-2xl flex-col items-center px-4 py-28 text-center sm:px-6"
>
  <p class="font-display text-7xl font-bold text-brand-600 sm:text-8xl">404</p>
  <h1 class="mt-6 font-display text-3xl font-bold text-ink-900 sm:text-4xl">{copy.title}</h1>
  <p class="mt-4 max-w-md text-lg leading-relaxed text-ink-600">{copy.body}</p>
  <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
    <a
      href={localizePath('/', lang)}
      class="inline-flex items-center rounded-pill bg-brand-600 px-6 py-3 text-base font-semibold text-white shadow-lift transition-all hover:bg-brand-700"
    >
      {copy.home}
    </a>
    <a
      href={localizePath('/catalog', lang)}
      class="inline-flex items-center rounded-pill border border-ink-200 bg-surface px-6 py-3 text-base font-semibold text-ink-700 transition-all hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700"
    >
      {copy.catalog}
    </a>
  </div>
</BaseLayout>
