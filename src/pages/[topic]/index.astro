---
/**
 * Topic landing (English) — header (icon/title/tagline/description + MDX body)
 * and an ordered list of the topic's lessons.
 */
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CourseComplete } from '@/components/react';
import { getLessons, getTopicEntry, topicPaths, getTopicAlternates } from '@/lib/content';
import { useTranslations, localizePath } from '@/i18n/utils';

export async function getStaticPaths() {
  return topicPaths('en');
}

const lang = 'en' as const;
const { topicSlug } = Astro.props;
const t = useTranslations(lang);

const topic = await getTopicEntry(lang, topicSlug);
if (!topic) {
  return Astro.redirect(localizePath('/catalog', lang));
}

const { Content } = await render(topic);
const lessons = await getLessons(lang, topicSlug);
const alts = await getTopicAlternates(`/${topicSlug}`);
---

<BaseLayout
  title={topic.data.seo.title ?? topic.data.title}
  description={topic.data.seo.description ?? topic.data.description}
  lang={lang}
  alternates={alts}
  keywords={topic.data.seo.keywords}
  noindex={topic.data.seo.noindex}
  mainClass="mx-auto w-full max-w-4xl px-4 pb-20 pt-10 sm:px-6"
>
  <header class="animate-fade-up">
    <span class="grid h-14 w-14 place-items-center rounded-card bg-brand-50 text-3xl">
      {topic.data.icon}
    </span>
    <h1 class="mt-5 font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      {topic.data.title}
    </h1>
    {
      topic.data.tagline && (
        <p class="mt-2 font-display text-lg font-medium text-brand-700">{topic.data.tagline}</p>
      )
    }
    <p class="mt-3 max-w-2xl text-lg leading-relaxed text-ink-600">{topic.data.description}</p>
  </header>

  <div class="prose prose-lg prose-lesson mt-8 max-w-none">
    <Content />
  </div>

  <section class="mt-12">
    <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-ink-400">
      {t('lesson.inTopic')}
    </h2>
    {
      lessons.length === 0 ? (
        <p class="mt-4 text-ink-500">No lessons yet.</p>
      ) : (
        <ol class="mt-5 space-y-3">
          {lessons.map((l, i) => (
            <li>
              <a
                href={localizePath(`/${l.topicSlug}/${l.lessonSlug}`, lang)}
                class="group flex items-center gap-4 rounded-card border border-ink-200 bg-surface p-4 shadow-soft transition-all hover:border-brand-300 hover:shadow-lift sm:p-5"
              >
                <span class="grid h-9 w-9 shrink-0 place-items-center rounded-pill bg-brand-50 font-display text-sm font-semibold text-brand-700">
                  {i + 1}
                </span>
                <span class="min-w-0 flex-1">
                  <span class="block font-display font-semibold text-ink-900 group-hover:text-brand-700">
                    {l.entry.data.title}
                  </span>
                  <span class="mt-0.5 block truncate text-sm text-ink-500">
                    {l.entry.data.description}
                  </span>
                </span>
                {l.entry.data.minutes != null && (
                  <span class="shrink-0 text-xs font-medium text-ink-400">
                    {l.entry.data.minutes} {t('lesson.minutes')}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </section>

  {
    lessons.length > 0 && (
      <CourseComplete
        client:visible
        slug={topicSlug}
        lessonSlugs={lessons.map((l) => l.lessonSlug)}
        markLabel={t('course.markFinished')}
        finishedLabel={t('course.finished')}
        markHint={t('course.markHint')}
        finishedHint={t('course.finishedHint')}
        undoLabel={t('course.undo')}
        lessonsLabel={t('catalog.lessons')}
        completedLabel={t('course.completed')}
        className="mt-10"
      />
    )
  }
</BaseLayout>
