---
/**
 * Catalog (English) — every topic plotted as a dependency graph
 * (roadmap.sh-style) so the learning order and prerequisites are clear.
 * Adding a course needs no change here: drop a topic MDX with a
 * `dependencies` array and it appears, wired to its prerequisites.
 * Learning paths are just the tag filter: /catalog?tag=<tag>.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CourseGraph, ProgressTransfer } from '@/components/react';
import { getCourseNodes, getDifficultyLabels, getTagOptions } from '@/lib/catalog';
import { useTranslations, alternates as alternatesFor } from '@/i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const nodes = await getCourseNodes(lang);
const difficultyLabels = getDifficultyLabels(lang);
const tagOptions = await getTagOptions(lang);

const alts = alternatesFor(Astro.url).map((a) => ({ lang: a.lang, href: a.path }));
---

<BaseLayout
  title={t('catalog.title')}
  description={t('catalog.subtitle')}
  lang={lang}
  alternates={alts}
  mainClass="mx-auto w-full max-w-[100rem] px-4 pb-20 pt-12 sm:px-6"
>
  <header class="max-w-2xl animate-fade-up">
    <h1 class="font-display text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      {t('catalog.title')}
    </h1>
    <p class="mt-3 text-lg leading-relaxed text-ink-600">{t('catalog.subtitle')}</p>
  </header>

  <div class="mt-8">
    <ProgressTransfer
      client:visible
      title={t('progress.title')}
      description={t('progress.description')}
      exportLabel={t('progress.export')}
      importLabel={t('progress.import')}
      countLabel={t('progress.count')}
      importedLabel={t('progress.imported')}
      noNewLabel={t('progress.noNew')}
      errorLabel={t('progress.error')}
    />
  </div>

  <div class="mt-12">
    <CourseGraph
      client:visible
      nodes={nodes}
      lessonsLabel={t('catalog.lessons')}
      difficultyLabels={difficultyLabels}
      finishedLabel={t('catalog.completed')}
      caption={t('catalog.graphHint')}
      emptyLabel="No topics yet — check back soon."
      levelLabel={t('catalog.filterLevel')}
      allLevelsLabel={t('catalog.allLevels')}
      tagOptions={tagOptions}
      tagsLabel={t('catalog.filterTags')}
      allTagsLabel={t('catalog.allTags')}
      comingSoonLabel={t('catalog.comingSoon')}
    />
  </div>
</BaseLayout>
